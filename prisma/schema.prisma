generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model alembic_version {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)
}

model calendar_entries {
  id                  String               @id @db.Uuid
  calendar_id         String               @db.Uuid
  week_number         Int?
  scheduled_date      DateTime?            @db.Date
  platform            String               @db.VarChar(100)
  content_type        String               @db.VarChar(100)
  title               String
  objective           String
  event_reference     String?
  weather_context     String?
  notes               String?
  status              String               @db.VarChar(50)
  order_index         Int
  created_at          DateTime             @default(now()) @db.Timestamptz(6)
  marketing_calendars marketing_calendars  @relation(fields: [calendar_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  generated_contents  generated_contents[]

  @@index([calendar_id], map: "ix_calendar_entries_calendar_id")
}

model generated_contents {
  id                  String               @id @db.Uuid
  user_id             String               @db.Uuid
  calendar_id         String?              @db.Uuid
  calendar_entry_id   String?              @db.Uuid
  status              String               @db.VarChar(50)
  content_format      String               @db.VarChar(50)
  platform            String?              @db.VarChar(100)
  title               String?
  body                String?
  hashtags            Json?
  local_context       Json?
  premium_features    Json?
  ab_variant          String?              @db.VarChar(20)
  image_prompt        String?
  image_url           String?
  export_batch_id     String?              @db.Uuid
  metadata            Json?
  created_at          DateTime             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime             @default(now()) @db.Timestamptz(6)
  calendar_entries    calendar_entries?    @relation(fields: [calendar_entry_id], references: [id], onUpdate: NoAction)
  marketing_calendars marketing_calendars? @relation(fields: [calendar_id], references: [id], onUpdate: NoAction)
  source_citations    source_citations[]

  @@index([calendar_entry_id], map: "ix_generated_contents_calendar_entry_id")
  @@index([calendar_id], map: "ix_generated_contents_calendar_id")
  @@index([export_batch_id], map: "ix_generated_contents_export_batch_id")
  @@index([user_id], map: "ix_generated_contents_user_id")
}

model marketing_calendars {
  id                   String               @id @db.Uuid
  user_id              String               @db.Uuid
  year                 Int
  month                Int
  status               String               @db.VarChar(50)
  is_strategy_approved Boolean              @default(false)
  is_calendar_approved Boolean              @default(false)
  strategy_summary     String?
  generation_context   Json?
  created_at           DateTime             @default(now()) @db.Timestamptz(6)
  updated_at           DateTime             @default(now()) @db.Timestamptz(6)
  calendar_entries     calendar_entries[]
  generated_contents   generated_contents[]
  scraped_sources      scraped_sources[]

  @@index([user_id], map: "ix_marketing_calendars_user_id")
}

model scraped_sources {
  id                  String              @id @db.Uuid
  calendar_id         String              @db.Uuid
  source_type         String              @db.VarChar(50)
  source_category     String              @db.VarChar(50)
  url                 String
  domain              String              @db.VarChar(255)
  title               String
  snippet             String?
  relevance_score     Float               @default(0.5)
  scraped_at          DateTime            @db.Timestamptz(6)
  created_at          DateTime            @default(now()) @db.Timestamptz(6)
  cache_key           String?             @db.VarChar(255)
  expires_at          DateTime?           @db.Timestamptz(6)
  is_shared           Boolean             @default(false)
  scope_city          String?             @db.VarChar(255)
  scope_sector        String?             @db.VarChar(255)
  marketing_calendars marketing_calendars @relation(fields: [calendar_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  source_citations    source_citations[]

  @@index([cache_key], map: "ix_scraped_sources_cache_key")
  @@index([calendar_id], map: "ix_scraped_sources_calendar_id")
  @@index([expires_at], map: "ix_scraped_sources_expires_at")
  @@index([url], map: "ix_scraped_sources_url")
}

model source_citations {
  id                   String             @id @db.Uuid
  generated_content_id String             @db.Uuid
  source_id            String             @db.Uuid
  influence_type       String             @db.VarChar(50)
  confidence           Float              @default(0.5)
  created_at           DateTime           @default(now()) @db.Timestamptz(6)
  generated_contents   generated_contents @relation(fields: [generated_content_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  scraped_sources      scraped_sources    @relation(fields: [source_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([generated_content_id], map: "ix_source_citations_generated_content_id")
  @@index([source_id], map: "ix_source_citations_source_id")
}

// ─────────────────────────────────────────
// AUTH — Utilisateurs et sessions
// ─────────────────────────────────────────

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique @db.VarChar(255)
  password      String         @db.VarChar(255)
  firstName     String?        @map("first_name") @db.VarChar(100)
  lastName      String?        @map("last_name") @db.VarChar(100)
  role          String         @default("VIEWER") @db.VarChar(20)
  isActive      Boolean        @default(true) @map("is_active")
  emailVerified Boolean        @default(false) @map("email_verified")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)

  refreshTokens RefreshToken[]

  @@map("users")
  @@index([email], map: "ix_users_email")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique @db.VarChar(512)
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("refresh_tokens")
  @@index([userId], map: "ix_refresh_tokens_user_id")
  @@index([token], map: "ix_refresh_tokens_token")
}

// ─────────────────────────────────────────
// TENANT — L'entreprise (cœur du multi-tenant)
// company_id links this CRM tenant 1:1 to the
// FastAPI companies table (shared PostgreSQL DB).
// ─────────────────────────────────────────
model Tenant {
  id        String   @id @default(cuid())
  name      String
  userId    String?  @unique @map("user_id") @db.Uuid
  companyId String?  @unique @map("company_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  leads     Lead[]
  tags      Tag[]
  workflows Workflow[]

  @@map("Tenant")
  @@index([userId])
}

// ─────────────────────────────────────────
// LEAD — Le contact client (US18)
// ─────────────────────────────────────────
model Lead {
  id        String     @id @default(uuid())
  firstName String?
  lastName  String?
  email     String
  phone     String?
  status    LeadStatus @default(NOUVEAU)
  source    LeadSource @default(MANUEL)
  notes     String?

  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  tags       Tag[]               @relation("LeadTags")
  executions WorkflowExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, tenantId])
  @@index([tenantId])
}

enum LeadStatus {
  NOUVEAU
  QUALIFIE
  CONVERTI
  INACTIF
}

enum LeadSource {
  MANUEL
  CSV_IMPORT
  FORMULAIRE
  RESEAU_SOCIAL
}

// ─────────────────────────────────────────
// TAG — Segmentation des contacts (US19)
// ─────────────────────────────────────────
model Tag {
  id       String  @id @default(uuid())
  label    String
  color    String? 

  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  leads    Lead[]  @relation("LeadTags")

  createdAt DateTime @default(now())

  @@unique([label, tenantId])
  @@index([tenantId])
}

// ─────────────────────────────────────────
// WORKFLOW — Automatisation de suivi (US20)
// ─────────────────────────────────────────
model Workflow {
  id           String   @id @default(cuid())
  name         String
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trigger      String   // "tag_added" | "status_changed" | "manual" | "import"
  triggerValue String?  // ex: "VIP" pour tag_added, "QUALIFIE" pour status_changed
  steps        Json     // [{ type: "send_email"|"change_status"|"wait", value: String, delayDays: Int }]
  isActive     Boolean  @default(true)
  executions   WorkflowExecution[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@index([tenantId])
}

model WorkflowExecution {
  id            String    @id @default(cuid())
  workflowId    String
  workflow      Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  leadId        String
  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  currentStep   Int       @default(0)
  currentNodeId String?   // current node id in the graph (graph-based execution)
  eventValue    String?   // value that triggered the workflow (e.g. tag name)
  status        String    @default("running") // "running" | "waiting" | "completed" | "failed"
  resumeAt      DateTime? // when to resume after a wait step
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([workflowId])
  @@index([leadId])
  @@index([status, resumeAt])
}

// ─────────────────────────────────────────
// NOTIFICATIONS — Alertes temps réel
// Table créée par Alembic (Python backend)
// ─────────────────────────────────────────
model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(200)
  message   String   @db.VarChar(500)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("notifications")
  @@index([userId], map: "ix_notifications_user_id")
  @@index([userId, isRead], map: "ix_notifications_user_id_is_read")
}

model companies {
  id                String       @id @db.Uuid
  user_id           String       @db.Uuid
  company_name      String?      @db.VarChar(255)
  activity_sector   String?      @db.VarChar(255)
  city              String?      @db.VarChar(255)
  country           String?      @db.VarChar(255)
  target_audience   String?
  main_objective    String?
  tone_of_voice     String?      @db.VarChar(100)
  platforms         Json?
  logo_url          String?
  logo_step_done    Boolean      @default(false)
  is_completed      Boolean      @default(false)
  marketing_profile Json?
  created_at        DateTime     @default(now()) @db.Timestamptz(6)
  competitors       competitors[]

  @@index([user_id], map: "ix_companies_user_id")
}

model onboarding_messages {
  id         String   @id @db.Uuid
  user_id    String   @db.Uuid
  role       String   @db.VarChar(10)
  content    String
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([user_id], map: "ix_onboarding_messages_user_id")
}

model competitors {
  id            String    @id @db.Uuid
  company_id    String    @db.Uuid
  name          String    @db.VarChar(255)
  website_url   String?
  facebook_url  String?
  instagram_url String?
  tiktok_url    String?
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  company       companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id], map: "ix_competitors_company_id")
}

// ─────────────────────────────────────────
// SUBSCRIPTIONS — mirrored from FastAPI / Alembic (read-write, same DB)
// ─────────────────────────────────────────

model plans {
  id                  String          @id @db.Uuid
  name                String          @db.VarChar(100)
  slug                String          @unique @db.VarChar(50)
  price_monthly_cents Int
  features            Json
  is_active           Boolean         @default(true)
  stripe_price_id     String?         @db.VarChar(255)
  created_at          DateTime        @default(now()) @db.Timestamptz(6)

  subscriptions subscriptions[]
}

model subscriptions {
  id                     String    @id @db.Uuid
  company_id             String    @db.Uuid
  plan_id                String    @db.Uuid
  status                 String    @db.VarChar(20)
  period_type            String    @db.VarChar(20)
  stripe_customer_id     String?   @db.VarChar(255)
  stripe_subscription_id String?   @db.VarChar(255)
  started_at             DateTime  @default(now()) @db.Timestamptz(6)
  ends_at                DateTime? @db.Timestamptz(6)
  created_at             DateTime  @default(now()) @db.Timestamptz(6)

  plan plans @relation(fields: [plan_id], references: [id])

  @@index([company_id])
  @@index([status])
  @@index([stripe_subscription_id])
}

model usage_logs {
  id           String   @id @db.Uuid
  company_id   String   @db.Uuid
  feature_key  String   @db.VarChar(100)
  period_start DateTime @db.Date
  used_at      DateTime @default(now()) @db.Timestamptz(6)

  @@index([company_id])
  @@index([feature_key])
}

model webhook_events {
  id               String   @id @db.Uuid
  stripe_event_id  String   @unique @db.VarChar(255)
  event_type       String   @db.VarChar(100)
  status           String   @db.VarChar(20)
  error_message    String?
  livemode         Boolean  @default(false)
  raw_payload      Json?
  processed_at     DateTime @default(now()) @db.Timestamptz(6)

  @@index([stripe_event_id])
  @@index([event_type])
  @@index([status])
}

model brand_assets {
  id          String   @id @db.Uuid
  user_id     String   @db.Uuid
  asset_type  String   @db.VarChar(20)
  file_url    String
  main_colors Json?
  style_tags  Json?
  ai_analysis Json?
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@index([user_id], map: "ix_brand_assets_user_id")
}

model content_examples {
  id               String   @id @db.Uuid
  platform         String   @db.VarChar(50)
  content_type     String   @db.VarChar(50)
  sector           String   @db.VarChar(100)
  country          String   @default("FR") @db.VarChar(5)
  region           String?  @db.VarChar(100)
  city             String?  @db.VarChar(100)
  language         String   @default("fr") @db.VarChar(10)
  objective        String?  @db.VarChar(100)
  tone             String?  @db.VarChar(50)
  body             String
  hashtags         Json     @default("[]")
  image_prompt     String?
  engagement_rate  Float?
  has_local_anchor Boolean  @default(false)
  has_cultural_ref Boolean  @default(false)
  source           String   @db.VarChar(20)
  embedding        Unsupported("vector(384)")? 
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)

  @@index([embedding], map: "ix_content_examples_embedding")
  @@index([hashtags], map: "ix_content_examples_hashtags")
  @@index([sector, platform, source], map: "ix_content_examples_sector_platform_source")
}
